# Context Capture Environment Configuration

# --- LLM Providers (pick one) ---

# Option 1: Claude (production, requires API key)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Option 2: Ollama (local, free, for testing)
# Set USE_OLLAMA=true to use local Ollama instead of Claude
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Optional Enhancements ---

# Firecrawl for better scraping quality (optional)
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# --- Notes ---
# Get Anthropic API key: https://console.anthropic.com/
# Get Firecrawl API key: https://firecrawl.dev
# Install Ollama: https://ollama.com
# Default model: llama3.2 (run: ollama pull llama3.2)
